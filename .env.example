# Copy to .env and fill in real values. Never commit .env.
# OANDA_ENVIRONMENT must stay "practice" until Phase 11 live gate.

OANDA_ACCOUNT_ID=000-000-0000000-000
OANDA_ACCESS_TOKEN=your_32hex_token-your_32hex_token_here
OANDA_ENVIRONMENT=practice

# Optional -- only needed to run scripts/fetch_policy_rates.py (TRADING-RULES §6 slot 2
# carry hearing). Free key: fredaccount.stlouisfed.org/apikeys.
FRED_API_KEY=your_fred_api_key_here

DATABASE_URL=sqlite:///instance/journal.db

FLASK_SECRET_KEY=change_me_to_a_long_random_string

DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change_me
